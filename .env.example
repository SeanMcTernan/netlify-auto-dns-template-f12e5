# Personal Access Token for the customer's Netlify account.
# Create at: User settings -> Applications -> Personal access tokens.
# Needs access to the team that owns the sites and the DNS zone.
NETLIFY_API_TOKEN=

# The team (account) slug whose sites should be watched.
# Find it in the team's URL: app.netlify.com/teams/<this-part>/...
NETLIFY_ACCOUNT_SLUG=

# Base domain new sites are placed under. A new site "custard" becomes
# custard.<BASE_DOMAIN>. This domain (or its apex) must be a Netlify-managed DNS zone.
BASE_DOMAIN=vibecode.company.com

# Provisioned automatically by Netlify DB (`netlify db init`). Do not set by hand.
# NETLIFY_DATABASE_URL=
